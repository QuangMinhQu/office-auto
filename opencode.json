{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "orchestrator",
  "instructions": [
    ".opencode/AGENTS.md",
    ".opencode/memory/project.md"
  ],
  "mcp": {
    "office-auto": {
      "type": "local",
      "command": [
        "node",
        "--import",
        "tsx",
        "mcp/office-auto-server.ts"
      ],
      "enabled": true,
      "environment": {
        "OFFICE_AUTO_WORKSPACE": "{cwd}"
      }
    }
  },
  "permission": {
    "mcp_officecli_*": "deny"
  }
}
