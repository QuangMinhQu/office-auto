{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://office-auto.dev/schemas/run.schema.json",
  "title": "Run State Schema",
  "description": "Schema for run.json — the derived snapshot from events.jsonl. Source of truth is events.jsonl. This file is a cache rebuilt by the reducer.",
  "type": "object",
  "required": ["run_id", "pipeline_version", "phase", "inputs", "final_gate"],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique run identifier (timestamp format: YYYYMMDDTHHMMSS_template)."
    },
    "pipeline_version": {
      "type": "string",
      "enum": ["2", "3"],
      "description": "Pipeline version. v3 = deterministic compiler + durable workflow, v2 = legacy LLM-driven."
    },
    "phase": {
      "type": "string",
      "enum": [
        "created",
        "inspecting", "inspected",
        "source_parsing", "source_parsed",
        "mapping", "mapped",
        "compiling", "compiled",
        "validating", "validated",
        "applying", "applied",
        "verifying", "verified",
        "qa", "qa_passed",
        "reviewing", "reviewed",
        "refreshing", "refreshed",
        "final_gate",
        "complete", "failed", "paused"
      ],
      "description": "Current pipeline phase. Governed by transition guard in transitions.ts."
    },
    "status": {
      "type": "string",
      "enum": ["running", "paused", "failed", "complete"],
      "description": "Run lifecycle status. Phase tracks workflow step; status tracks lifecycle."
    },
    "inputs": {
      "type": "object",
      "required": ["template_file", "source_file", "target_file"],
      "properties": {
        "template_file": { "type": "string" },
        "source_file": { "type": "string" },
        "target_file": { "type": "string" },
        "strict_mode": { "type": "boolean" }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "Map of artifact names to ArtifactRef (path + sha256 + schema + created_by + phase + valid). Not just file paths.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" },
          "schema": { "type": "string" },
          "created_by": { "type": "string" },
          "phase": { "type": "string" },
          "valid": { "type": "boolean" }
        },
        "required": ["path", "sha256", "valid"]
      }
    },
    "agents": {
      "type": "object",
      "description": "Subagent run states (pending/running/completed/failed).",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "agent_id": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "running", "completed", "failed"] },
          "started_at": { "type": "string" },
          "completed_at": { "type": "string" },
          "error": { "type": "string" }
        }
      }
    },
    "decisions": {
      "type": "object",
      "description": "LLM decisions (style_map, replace_range).",
      "properties": {
        "style_map": { "$ref": "#/properties/artifacts/additionalProperties" },
        "replace_range": { "$ref": "#/properties/artifacts/additionalProperties" },
        "human_overrides": {
          "type": "array",
          "items": { "$ref": "#/properties/artifacts/additionalProperties" }
        }
      }
    },
    "checks": {
      "type": "object",
      "description": "Validation check results from each gate.",
      "properties": {
        "strict_validation": {
          "type": "object",
          "properties": {
            "passed": { "type": "boolean" },
            "details": { "type": "object" },
            "errors": { "type": "array", "items": { "type": "string" } },
            "warnings": { "type": "array", "items": { "type": "string" } }
          }
        },
        "execution": { "$ref": "#/properties/checks/properties/strict_validation" },
        "coverage": { "$ref": "#/properties/checks/properties/strict_validation" },
        "qa": { "$ref": "#/properties/checks/properties/strict_validation" },
        "review": { "$ref": "#/properties/checks/properties/strict_validation" },
        "final_gate": { "$ref": "#/properties/checks/properties/strict_validation" }
      }
    },
    "errors": {
      "type": "array",
      "description": "Pipeline errors with phase, agent, message, code, recoverable flag.",
      "items": {
        "type": "object",
        "properties": {
          "phase": { "type": "string" },
          "agent": { "type": "string" },
          "message": { "type": "string" },
          "code": { "type": "string" },
          "timestamp": { "type": "string" },
          "recoverable": { "type": "boolean" }
        }
      }
    },
    "revision": {
      "type": "integer",
      "description": "Monotonic revision counter. Incremented on every event.",
      "minimum": 0
    },
    "created_at": { "type": "string", "description": "ISO 8601 creation timestamp." },
    "updated_at": { "type": "string", "description": "ISO 8601 last update timestamp." },
    "final_gate": {
      "type": "object",
      "required": ["passed"],
      "properties": {
        "passed": { "type": "boolean" }
      }
    }
  }
}
