{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://office-auto.dev/schemas/execution_ops.schema.json",
  "title": "Execution Ops Schema",
  "description": "Schema for execution_ops.json — the ops blueprint applied by execute_execution_ops.py. Generated deterministically by source_packet_to_ops.py.",
  "type": "object",
  "required": ["version", "ops"],
  "properties": {
    "version": {
      "type": "string",
      "const": "2",
      "description": "Schema version. Only version 2 is supported."
    },
    "source_sha256": {
      "type": "string",
      "description": "SHA-256 hash of the source markdown file for integrity verification."
    },
    "source_file": {
      "type": "string",
      "description": "Absolute path to the source markdown file."
    },
    "first_insert_anchor": {
      "type": "string",
      "description": "The first insert op's anchor path (paraId-based)."
    },
    "compiled_by": {
      "type": "string",
      "description": "Name of the script that compiled these ops (source_packet_to_ops.py)."
    },
    "ops": {
      "type": "array",
      "description": "Ordered list of operations to apply.",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/insert_paragraph_after"
          },
          {
            "$ref": "#/$defs/insert_paragraph_before"
          },
          {
            "$ref": "#/$defs/remove"
          },
          {
            "$ref": "#/$defs/update_text"
          },
          {
            "$ref": "#/$defs/insert_table"
          },
          {
            "$ref": "#/$defs/set_page_layout"
          },
          {
            "$ref": "#/$defs/insert_image"
          }
        ]
      }
    }
  },
  "$defs": {
    "insert_paragraph_after": {
      "type": "object",
      "required": ["op", "role", "anchor", "style", "text"],
      "properties": {
        "op": { "const": "insert_paragraph_after" },
        "role": { "type": "string", "enum": ["h1", "h2", "h3", "body", "toc"], "description": "Semantic role for validation/QA." },
        "anchor": { "type": "string", "description": "Path or PREVIOUS keyword." },
        "style": { "type": "string", "description": "DOCX style_id for this paragraph." },
        "text": { "type": "string", "description": "Exact text content — never paraphrased." },
        "source_block_id": { "type": "string", "description": "ID from source_packet.json for traceability." },
        "source_text_sha256": { "type": "string", "description": "SHA-256 of the source block text." },
        "run_props": {
          "type": "object",
          "description": "Optional run-level properties (font, size, bold, italic). Never set on headings.",
          "properties": {
            "font": { "type": "string" },
            "size_pt": { "type": "number" },
            "bold": { "type": "boolean" },
            "italic": { "type": "boolean" }
          }
        },
        "para_props": {
          "type": "object",
          "description": "Optional paragraph-level properties.",
          "properties": {
            "first_line_indent_pt": { "type": "number" },
            "line_spacing": { "type": "number" },
            "space_before_pt": { "type": "number" },
            "space_after_pt": { "type": "number" }
          }
        },
        "bookmark": { "type": "string", "description": "Optional bookmark ID for TOC linking." }
      }
    },
    "insert_paragraph_before": {
      "type": "object",
      "required": ["op", "role", "anchor", "style", "text"],
      "properties": {
        "op": { "const": "insert_paragraph_before" },
        "role": { "type": "string", "enum": ["h1", "h2", "h3", "body"] },
        "anchor": { "type": "string" },
        "style": { "type": "string" },
        "text": { "type": "string" },
        "source_block_id": { "type": "string" },
        "source_text_sha256": { "type": "string" },
        "run_props": { "type": "object" },
        "para_props": { "type": "object" }
      }
    },
    "remove": {
      "type": "object",
      "required": ["op", "path"],
      "properties": {
        "op": { "const": "remove" },
        "path": { "type": "string", "description": "Must use 'path' not 'at'. Format: /body/p[@paraId=XXXX]." }
      }
    },
    "update_text": {
      "type": "object",
      "required": ["op", "path"],
      "properties": {
        "op": { "const": "update_text" },
        "path": { "type": "string" },
        "text": { "type": "string" },
        "run_props": { "type": "object" }
      }
    },
    "insert_table": {
      "type": "object",
      "required": ["op", "anchor", "rows"],
      "properties": {
        "op": { "const": "insert_table_after" },
        "anchor": { "type": "string" },
        "rows": { "type": "array" },
        "col_widths": { "type": "array", "items": { "type": "number" } },
        "style": { "type": "string" }
      }
    },
    "set_page_layout": {
      "type": "object",
      "required": ["op"],
      "properties": {
        "op": { "const": "set_page_layout" },
        "margins": {
          "type": "object",
          "properties": {
            "top": { "type": "number" },
            "bottom": { "type": "number" },
            "left": { "type": "number" },
            "right": { "type": "number" }
          }
        },
        "paper_size": { "type": "string" },
        "orientation": { "type": "string", "enum": ["portrait", "landscape"] }
      }
    },
    "insert_image": {
      "type": "object",
      "required": ["op", "anchor", "image_path"],
      "properties": {
        "op": { "const": "insert_image" },
        "anchor": { "type": "string" },
        "image_path": { "type": "string" },
        "width_cm": { "type": "number" },
        "caption": { "type": "string" },
        "caption_style": { "type": "string" }
      }
    }
  }
}
