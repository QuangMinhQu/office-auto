{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["mcp/**/*.ts", ".opencode/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"]
}
