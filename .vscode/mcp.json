{
  "servers": {
    "officecli": {
      "type": "stdio",
      "command": "officecli",
      "args": [
        "mcp"
      ]
    },
    "codegraph": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@cartographai/mcp-server-codegraph",
        "${workspaceFolder}"
      ]
    }
  }
}