{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "docxRunId",
      "type": "promptString",
      "description": "Run id dưới .office-auto/state cho build DOCX",
      "default": "vscode-docx-run"
    }
  ],
  "tasks": [
    {
      "label": "Office Auto: Build DOCX Report",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/build_report.py",
        "--run-dir",
        ".office-auto/state/${input:docxRunId}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Office Auto: Latest Review Summary",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/latest_review_artifacts.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Office Auto: Latest Review Summary (JSON)",
      "type": "shell",
      "command": "python",
      "args": [
        "scripts/latest_review_artifacts.py",
        "--json"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Office Auto: Run Unit Tests",
      "type": "shell",
      "command": "python",
      "args": [
        "-m",
        "unittest",
        "discover",
        "-s",
        "tests"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}