{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Office Auto Run State",
  "type": "object",
  "required": [
    "mode",
    "template_file",
    "target_file",
    "artifacts",
    "status"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "preserve-template-scaffold",
        "replace-main-content-range",
        "fill-declared-placeholders",
        "append-structured-section",
        "full-regenerate-from-schema"
      ]
    },
    "mode_requested": {
      "type": ["string", "null"]
    },
    "source_file": {
      "type": ["string", "null"]
    },
    "template_file": {
      "type": "string"
    },
    "target_file": {
      "type": "string"
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "content_ast": {"type": "string"},
        "content_outline": {"type": "string"},
        "template_profile": {"type": "string"},
        "plan": {"type": "string"},
        "build_report": {"type": "string"},
        "qa_report": {"type": "string"}
      },
      "additionalProperties": true
    },
    "status": {
      "type": "string"
    },
    "preserve": {
      "type": "array",
      "items": {"type": "string"}
    },
    "replace_ranges": {
      "type": "array",
      "items": {"type": "object"}
    }
  },
  "additionalProperties": true
}